{
  "name": "ctrlztree",
  "displayName": "CtrlZTree",
  "description": "History of modifications in the form of a tree instead of a stack, like in the Undotree plugin.",
  "keywords": [
    "vscode",
    "extension",
    "undotree",
    "history",
    "tree",
    "ctrlz",
    "undo",
    "redo",
    "ctrlztree",
    "ctrl+z",
    "ctrl+y",
    "ctrl+shift+z"
  ],
  "version": "0.6.0",
  "publisher": "4skl",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/4skl/ctrlztree-undotree-vscode.git"
  },
  "engines": {
    "vscode": "^1.67.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onEditSession:file"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ctrlztree.undo",
        "title": "CtrlZTree: Undo"
      },
      {
        "command": "ctrlztree.redo",
        "title": "CtrlZTree: Redo"
      },
      {
        "command": "ctrlztree.history.refresh",
        "title": "CtrlZTree: Refresh History Tree"
      },
      {
        "command": "ctrlztree.history.navigateToNode",
        "title": "CtrlZTree: Navigate to Node"
      },
      {
        "command": "ctrlztree.history.diffWithParent",
        "title": "CtrlZTree: Diff with Parent"
      },
      {
        "command": "ctrlztree.history.diffWithCurrent",
        "title": "CtrlZTree: Diff with Current"
      },
      {
        "command": "ctrlztree.history.mergeChain",
        "title": "CtrlZTree: Merge Linear History Chain"
      },
      {
        "command": "ctrlztree.ai.setApiKey",
        "title": "CtrlZTree: Set AI API Key"
      },
      {
        "command": "ctrlztree.ai.clearApiKey",
        "title": "CtrlZTree: Clear AI API Key"
      },
      {
        "command": "ctrlztree.ai.testConnection",
        "title": "CtrlZTree: Test AI Connection"
      },
      {
        "command": "ctrlztree.ai.summarizeCurrentNode",
        "title": "CtrlZTree: AI Summarize Current Node"
      },
      {
        "command": "ctrlztree.ai.renameNode",
        "title": "CtrlZTree: AI Rename Node"
      },
      {
        "command": "ctrlztree.ai.summarizeNode",
        "title": "CtrlZTree: AI Summarize Node"
      },
      {
        "command": "ctrlztree.ai.proposeMerge",
        "title": "CtrlZTree: AI Propose Merge"
      }
    ],
    "keybindings": [
      {
        "command": "ctrlztree.undo",
        "key": "ctrl+z",
        "mac": "cmd+z",
        "when": "editorTextFocus"
      },
      {
        "command": "ctrlztree.redo",
        "key": "ctrl+y",
        "mac": "cmd+y",
        "when": "editorTextFocus"
      },
      {
        "command": "ctrlztree.redo",
        "key": "ctrl+shift+z",
        "mac": "cmd+shift+z",
        "when": "editorTextFocus"
      }
    ],
    "views": {
      "ctrlztree": [
        {
          "id": "ctrlztree.history",
          "name": "History"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ctrlztree",
          "title": "CtrlZTree",
          "icon": "$(history)"
        }
      ]
    },
    "menus": {
      "view/item/context": [
        {
          "command": "ctrlztree.history.diffWithCurrent",
          "when": "view == ctrlztree.history && viewItem =~ /ctrlztree.node/"
        },
        {
          "command": "ctrlztree.history.diffWithParent",
          "when": "view == ctrlztree.history && viewItem =~ /ctrlztree.node/"
        },
        {
          "command": "ctrlztree.history.navigateToNode",
          "when": "view == ctrlztree.history && viewItem =~ /ctrlztree.node/"
        },
        {
          "command": "ctrlztree.ai.renameNode",
          "when": "view == ctrlztree.history && viewItem =~ /ctrlztree.node/",
          "group": "ai@1"
        },
        {
          "command": "ctrlztree.ai.summarizeNode",
          "when": "view == ctrlztree.history && viewItem =~ /ctrlztree.node/",
          "group": "ai@2"
        }
      ]
    },
    "configuration": {
      "title": "CtrlZTree",
      "properties": {
        "ctrlztree.enablePruning": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic history tree pruning to prevent unbounded memory growth"
        },
        "ctrlztree.maxHistoryNodesPerDocument": {
          "type": "integer",
          "default": 1000,
          "minimum": 50,
          "description": "Maximum number of history nodes to keep per document before pruning (minimum 50)"
        },
        "ctrlztree.maxTrackedDocuments": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "description": "Maximum number of documents to track simultaneously. Oldest histories are removed when exceeded"
        },
        "ctrlztree.ai.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable AI features (requires API key configured via CtrlZTree: Set AI API Key)"
        },
        "ctrlztree.ai.provider": {
          "type": "string",
          "default": "openai-chat-compatible",
          "enum": ["openai-chat-compatible", "anthropic-messages", "openai-responses", "custom-http-json"],
          "description": "AI provider type"
        },
        "ctrlztree.ai.model": {
          "type": "string",
          "default": "",
          "description": "Model name to use (e.g. gpt-4o-mini, claude-sonnet-4-6, deepseek-v4-flash)"
        },
        "ctrlztree.ai.baseUrl": {
          "type": "string",
          "default": "",
          "description": "API base URL for the provider (e.g. https://api.openai.com/v1/chat/completions)"
        },
        "ctrlztree.ai.timeoutMs": {
          "type": "integer",
          "default": 30000,
          "minimum": 5000,
          "maximum": 300000,
          "description": "Default timeout for AI requests in milliseconds"
        },
        "ctrlztree.ai.maxRetries": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "Maximum number of retries for failed AI requests"
        },
        "ctrlztree.ai.autoRename.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Automatically rename history nodes using AI after each commit"
        },
        "ctrlztree.ai.autoRename.debounceMs": {
          "type": "integer",
          "default": 2000,
          "minimum": 500,
          "maximum": 30000,
          "description": "Debounce delay in milliseconds before triggering auto-rename"
        },
        "ctrlztree.persistence.mode": {
          "type": "string",
          "default": "off",
          "enum": ["off", "ask", "on"],
          "markdownDescription": "History persistence mode. Changes take effect immediately. When switching from `off` to `on` or `ask`, existing open documents will be persisted on the next change. When switching to `off`, pending data is flushed to disk first. **Requires an encryption key to be stored in VS Code SecretStorage.**"
        },
        "ctrlztree.logging.level": {
          "type": "string",
          "default": "info",
          "enum": ["debug", "info", "warn", "error", "off"],
          "description": "Output channel log level. debug=verbose, info=normal, warn=warnings only, error=errors only, off=silent"
        },
        "ctrlztree.logging.moduleLevels": {
          "type": "object",
          "default": {},
          "description": "Per-module log level overrides. Keys are module names (e.g. 'ai', 'concurrency.scheduler'). Values: debug, info, warn, error, off.",
          "additionalProperties": {
            "type": "string",
            "enum": ["debug", "info", "warn", "error", "off"]
          }
        },
        "ctrlztree.logging.format": {
          "type": "string",
          "default": "text",
          "enum": ["text", "json"],
          "description": "Log output format: 'text' for human-readable, 'json' for machine-parseable"
        },
        "ctrlztree.treeView.maxDepth": {
          "type": "integer",
          "default": 4,
          "minimum": 1,
          "maximum": 8,
          "description": "Maximum depth of branch hierarchy in the tree view"
        },
        "ctrlztree.treeView.showTimestamps": {
          "type": "boolean",
          "default": true,
          "description": "Show timestamps next to tree nodes"
        },
        "ctrlztree.treeView.showHashPreview": {
          "type": "boolean",
          "default": true,
          "description": "Show shortened hash next to tree nodes"
        },
        "ctrlztree.treeView.previewLength": {
          "type": "integer",
          "default": 50,
          "minimum": 20,
          "maximum": 120,
          "description": "Maximum length of content preview in tree node labels"
        },
        "ctrlztree.treeView.showAiLabels": {
          "type": "boolean",
          "default": true,
          "description": "Show AI-generated names and summaries in the tree view when available"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "npm run test:clean && vscode-test --config ./.vscode-test.mjs",
    "test:clean": "node ./scripts/clean-vscode-test-env.mjs",
    "test:list": "vscode-test --config ./.vscode-test.mjs --list-configuration"
  },
  "devDependencies": {
    "@types/glob": "^7.1.1",
    "@types/json-schema": "^7.0.15",
    "@types/mocha": "^8.2.2",
    "@types/node": "^14.18.63",
    "@types/vscode": "^1.60.1",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^8.56.0",
    "glob": "^7.1.7",
    "mocha": "^11.5.0",
    "typescript": "^4.3.2"
  }
}
